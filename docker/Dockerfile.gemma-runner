FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_MODELS=/root/.ollama/models

# System deps
RUN apt-get update && apt-get install -y \
    curl python3 python3-pip ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama binary directly — avoids systemd dependency in install.sh
RUN curl -fsSL -o /usr/local/bin/ollama \
      https://github.com/ollama/ollama/releases/latest/download/ollama-linux-amd64 \
    && chmod +x /usr/local/bin/ollama

# Pull Gemma model at build time so it's baked into the image layer.
# Run ollama serve in background, wait for it, pull, then stop cleanly.
RUN /usr/local/bin/ollama serve & \
    OLLAMA_PID=$! && \
    sleep 8 && \
    /usr/local/bin/ollama pull gemma4:e4b && \
    printf 'FROM gemma4:e4b\nPARAMETER num_ctx 128000\n' > /tmp/Modelfile && \
    /usr/local/bin/ollama create gemma-local -f /tmp/Modelfile && \
    /usr/local/bin/ollama list && \
    kill $OLLAMA_PID 2>/dev/null || true

# Install LiteLLM proxy
RUN pip3 install 'litellm[proxy]'

# Write LiteLLM config that routes claude-3-haiku → gemma-local
RUN mkdir -p /etc/litellm && cat > /etc/litellm/config.yaml << 'EOF'
model_list:
  - model_name: claude-3-haiku-20240307
    litellm_params:
      model: ollama_chat/gemma-local
      api_base: http://localhost:11434
EOF

# Startup script: launch Ollama + LiteLLM in foreground
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 4000 11434

ENTRYPOINT ["/entrypoint.sh"]
